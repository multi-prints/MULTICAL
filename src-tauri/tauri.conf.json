{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-schema/master/tauri-conf.schema.json",
  "productName": "MULTIPRINTS",
  "version": "1.1.20",
  "identifier": "com.multiprints.desktop",
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MULTIPRINTS",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 520,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "build": {
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../src",
    "beforeDevCommand": {
      "script": "trunk serve --release --port 1420",
      "cwd": "../frontend"
    },
    "beforeBuildCommand": {
      "script": "trunk build",
      "cwd": "../frontend"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "Copyright © 2026 Godwin Mayodi",
    "category": "Business",
    "shortDescription": "Inventory and Sales Management",
    "longDescription": "A modern offline desktop inventory and sales management application for tracking products, stock, sales, and customer debts.",
    "linux": {
      "deb": {
        "depends": [],
        "postRemoveScript": "scripts/postrm.sh"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "nsis-uninstall-hooks.nsh"
      }
    }
  },
  "plugins": {}
}
