{
  "name": "multiprints",
  "version": "1.0.13",
  "description": "MULTIPRINTS - Offline Desktop Inventory and Sales Management Application",
  "main": "main/index.js",
  "author": {
    "name": "Godwin Mayodi",
    "email": "codegoddy@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/codegoddy/MULTICAL.git"
  },
  "homepage": "https://github.com/codegoddy/MULTICAL#readme",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dev": "electron . --dev --no-sandbox",
    "test": "echo \"Error: no test specified\" && exit 1",
    "rebuild": "electron-rebuild",
    "postinstall": "electron-rebuild",
    "build": "electron-builder build",
    "build:win": "electron-builder build --win",
    "build:mac": "electron-builder build --mac",
    "build:linux": "electron-builder build --linux",
    "build:all": "electron-builder build --win --mac --linux",
    "release": "electron-builder build --publish always"
  },
  "keywords": [
    "electron",
    "inventory",
    "sales",
    "desktop",
    "offline",
    "sqlite"
  ],
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^40.1.0",
    "electron-builder": "^26.4.0",
    "@electron/rebuild": "^4.0.1"
  },
  "build": {
    "appId": "com.multiprints.app",
    "productName": "MULTIPRINTS",
    "copyright": "Copyright © 2026 Godwin Mayodi",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main/**/*",
      "renderer/**/*",
      "shared/**/*",
      "database.js",
      "electron.config.js",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!node_modules/*.d.ts",
      "!node_modules/.bin"
    ],
    "extraResources": [
      {
        "from": "build/",
        "to": ".",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "npmRebuild": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MULTIPRINTS",
      "uninstallDisplayName": "MULTIPRINTS"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.business",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons",
      "category": "Office",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "synopsis": "Inventory and Sales Management",
      "description": "A modern offline desktop inventory and sales management application for tracking products, stock, sales, and customer debts.",
      "desktop": {
        "entry": {
          "Name": "MULTIPRINTS",
          "Comment": "Inventory and Sales Management",
          "Categories": "Office;Finance;Utility",
          "Type": "Application",
          "Terminal": "false"
        }
      }
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2"
  }
}
